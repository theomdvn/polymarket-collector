# Polymarket CLOB API (optionnel si pas d'auth)
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Assets à collecter (liste JSON)
ASSETS=["BTC","ETH","SOL","XRP"]

# Horizons à collecter
HORIZONS=["5m","15m"]

# Chemin d'export vers polymarket-backtest
BACKTEST_DATA_DIR=../polymarket-backtest/data
BACKTEST_EXPORT_INTERVAL=60
BACKTEST_LOOKBACK_SECONDS=3600
